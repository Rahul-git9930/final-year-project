# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/library_management

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Application URL
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Admin Email
ADMIN_EMAIL=admin@library.com

# Email Verification Configuration (NEW)
# Set to 'true' to enable email verification during registration
EMAIL_VERIFICATION_ENABLED=true

# Choose provider: apilayer, neverbounce, kickbox, mailercheck, emailable
EMAIL_VERIFICATION_PROVIDER=apilayer

# Your API key from the chosen provider
EMAIL_VERIFICATION_API_KEY=your_api_key_here

# Minimum email quality score (0-100) required for registration
# Lower = more permissive, Higher = more strict
# Recommended: 50 for balanced, 70 for strict
EMAIL_MIN_SCORE=50
